ANTHROPIC_API_KEY=sk-ant-...
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=quakemind
API_KEY=change-me-before-deploy
JMA_TIMEOUT=10.0
CLAUDE_MAX_RETRIES=3
POLL_INTERVAL_SECONDS=60
MAGNITUDE_THRESHOLD=4.0
DB_PATH=quakemind.db

# データベース
DATABASE_URL=postgresql+asyncpg://quakemind:quakemind_dev@localhost:5432/quakemind

# LLM プロバイダー ("local" | "claude")
LLM_PROVIDER=local
LOCAL_LLM_BASE_URL=http://127.0.0.1:8081
LOCAL_LLM_TIMEOUT=120.0
LOCAL_LLM_FALLBACK_TO_CLAUDE=true
